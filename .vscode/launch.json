{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "CursorRemote: Extension Dev Host",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "${workspaceFolder}/.vscode/cursor-remote-dev.code-workspace"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js",
        "${workspaceFolder}/dist/**/*.cjs"
      ]
    }
  ]
}
